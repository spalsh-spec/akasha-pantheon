# =============================================================
# AKASHA PANTHEON — example config
# Copy to .env and fill in. The .env file is gitignored.
# Provider order: ollama (default) → cloudflare → anthropic → openai
# =============================================================

# default oracle provider
ORACLE_PROVIDER=cloudflare

# ── FAST: local Ollama (no key needed; install ollama + `ollama pull gemma3:4b`) ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── DEEP: Cloudflare Workers AI (free tier; sign up at dash.cloudflare.com → AI → API tokens) ──
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# ── iCloud archive (optional) ──
ICLOUD_EXPORT_DIR=
EXPORT_ON_ASK=true

# ── Optional cloud providers (uncomment + fill if you want them) ──
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

PORT=3000
